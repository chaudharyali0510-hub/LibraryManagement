@model LibraryManagement.Models.BookIssue


<h3>
    Are you sure you want to delete this issue record?
</h3>


<p>
    Book:
    @Model.Book.Title
</p>


<p>
    Member:
    @Model.Member.FirstName @Model.Member.LastName
</p>


<form method="post">

    <input asp-for="Id" hidden />

    <button class="btn btn-danger">
        Delete
    </button>


    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>