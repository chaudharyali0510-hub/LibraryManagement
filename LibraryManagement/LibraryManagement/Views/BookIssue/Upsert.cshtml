@model LibraryManagement.Models.BookIssue

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />


<form method="post">

    @Html.AntiForgeryToken()

    <input asp-for="Id" hidden />


    <div asp-validation-summary="All"
         class="text-danger">
    </div>



    <div class="mb-3">

        <label>Book</label>

        <select asp-for="BookId"
                asp-items="ViewBag.Books"
                class="form-control select2">

            <option value="">
                Select Book
            </option>

        </select>

        <span asp-validation-for="BookId"
              class="text-danger">
        </span>

    </div>



    <div class="mb-3">

        <label>Member</label>

        <select asp-for="MemberId"
                asp-items="ViewBag.Members"
                class="form-control select2">

            <option value="">
                Select Member
            </option>

        </select>

        <span asp-validation-for="MemberId"
              class="text-danger">
        </span>

    </div>



    <div class="mb-3">

        <label asp-for="DateIssue"></label>

        <input asp-for="DateIssue"
               class="form-control"
                />

        <span asp-validation-for="DateIssue"
              class="text-danger">
        </span>

    </div>



    <div class="mb-3">

        <label asp-for="DueDate"></label>

        <input asp-for="DueDate"
               class="form-control" />

        <span asp-validation-for="DueDate"
              class="text-danger">
        </span>

    </div>



    <button type="submit"
            class="btn btn-success">

        Issue Book

    </button>


    <a asp-action="Index"
       class="btn btn-secondary">

        Back

    </a>


</form>



<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


<script>

    $(document).ready(function() {

        $(".select2").select2({
            width: "100%"
        });

    });

</script>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}