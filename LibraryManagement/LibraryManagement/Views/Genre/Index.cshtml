@model IEnumerable<Genre>

<div class="container">

    <h2>Genre</h2>

    <a asp-action="Upsert" class="btn btn-primary">
        Add Genre
    </a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                       @item.Name
                    </td>

                    <td>
                       @item.Description
                    </td>

                    <td>
                        <a asp-action="Upsert"
                           asp-route-id="@item.Id"
                           class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">
                            Delete
                        </a>
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>