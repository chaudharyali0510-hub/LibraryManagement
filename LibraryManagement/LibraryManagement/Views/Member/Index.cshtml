@inject IAuthorizationService AuthorizationService
@model IEnumerable<Member>

<div class="container">

    <h2>Members</h2>

    @if ((await AuthorizationService.AuthorizeAsync(User, "Members.Create")).Succeeded)
    {
        <a asp-action="Upsert" class="btn btn-primary">
            Add Member
        </a>
    }

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.FirstName @item.LastName
                    </td>

                    <td>
                        @item.Email
                    </td>

                    <td>
                        @item.PhoneNumber
                    </td>

                    <td>
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Members.Edit")).Succeeded)
                        {
                            <a asp-action="Upsert"
                               asp-route-id="@item.Id"
                               class="btn btn-warning">
                                Edit
                            </a>
                        }

                        @if ((await AuthorizationService.AuthorizeAsync(User, "Members.Delete")).Succeeded)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger">
                                Delete
                            </a>
                        }
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>
