@inject IAuthorizationService AuthorizationService
@model IEnumerable<Author>

<div class="container">

    <h2>Author</h2>

    @if ((await AuthorizationService.AuthorizeAsync(User, "Authors.Create")).Succeeded)
    {
        <a asp-action="Upsert" class="btn btn-primary">
            Add Author
        </a>
    }

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>DateOfBirt</th>
                <th>Nationality</th>
                <th></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.FirstName @item.LastName
                    </td>

                    <td>
                        @item.DateOfBirth
                    </td>

                    <td>
                        @item.Nationality
                    </td>

                    <td>
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Authors.Edit")).Succeeded)
                        {
                            <a asp-action="Upsert"
                               asp-route-id="@item.Id"
                               class="btn btn-warning">
                                Edit
                            </a>
                        }

                        @if ((await AuthorizationService.AuthorizeAsync(User, "Authors.Delete")).Succeeded)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger">
                                Delete
                            </a>
                        }
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>
