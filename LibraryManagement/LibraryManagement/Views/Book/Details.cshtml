@inject IAuthorizationService AuthorizationService
@model LibraryManagement.ViewModel.BookDetailsVM

@{
    var book = Model.Book;
    var isAvailable = book.AvailableCopies > 0;
}

<div class="container py-4">

    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Books
        </a>
    </div>

    <div class="row g-4">

        <div class="col-lg-5">
            <div class="card shadow-sm">
                @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                {
                    <img src="@book.CoverImageUrl" class="card-img-top" style="max-height:500px; object-fit:cover;" />
                }
                else
                {
                    <img src="https://placehold.co/500x400?text=No+Cover" class="card-img-top" style="max-height:500px; object-fit:cover;" />
                }
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-body">

                    <h2 class="mb-3">@book.Title</h2>

                    <div class="mb-3">
                        @foreach (var genre in book.BookGenres)
                        {
                            <span class="badge bg-secondary me-1 mb-1 fs-6">@genre.Genre?.Name</span>
                        }
                    </div>

                    <div class="mb-3">
                        @if (isAvailable)
                        {
                            <span class="badge bg-success fs-6">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">Out of Stock</span>
                        }
                    </div>

                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th style="width:180px;" class="text-muted">ISBN</th>
                                <td>@book.ISBN</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Author</th>
                                <td>@book.Author?.FirstName @book.Author?.LastName</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Publisher</th>
                                <td>@book.Publisher?.Name</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Publication Year</th>
                                <td>@book.PublicationYear</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Edition</th>
                                <td>@(book.Edition ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Language</th>
                                <td>@(book.Language ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Total Copies</th>
                                <td><span class="badge bg-primary">@book.TotalCopies</span></td>
                            </tr>
                            <tr>
                                <th class="text-muted">Available Copies</th>
                                <td>
                                    @if (isAvailable)
                                    {
                                        <span class="badge bg-success">@book.AvailableCopies</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">0</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    @if (!string.IsNullOrWhiteSpace(book.Description))
                    {
                        <hr />
                        <h5>Description</h5>
                        <p class="text-muted">@book.Description</p>
                    }

                </div>

                <div class="card-footer bg-white">
                    <div class="d-flex gap-2 flex-wrap">
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Books.Edit")).Succeeded)
                        {
                            <a asp-action="Upsert" asp-route-id="@book.Id" class="btn btn-warning">
                                <i class="fas fa-edit me-1"></i> Edit
                            </a>
                        }
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Issues.Create")).Succeeded && isAvailable)
                        {
                            <a asp-controller="BookIssue" asp-action="Upsert" asp-route-bookId="@book.Id" class="btn btn-success">
                                <i class="fas fa-book-open me-1"></i> Issue Book
                            </a>
                        }
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Books.Delete")).Succeeded)
                        {
                            <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-danger">
                                <i class="fas fa-trash me-1"></i> Delete
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

    @if (Model.ActiveIssues.Any())
    {
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-hand-holding me-2"></i>Current Borrowers</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Member</th>
                                <th>Issue Date</th>
                                <th>Due Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in Model.ActiveIssues)
                            {
                                <tr>
                                    <td>@issue.Member?.FirstName @issue.Member?.LastName</td>
                                    <td>@issue.DateIssue.ToShortDateString()</td>
                                    <td>@issue.DueDate.ToShortDateString()</td>
                                    <td>
                                        @if (issue.DueDate < DateTime.Now)
                                        {
                                            <span class="badge bg-danger">Overdue</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Active</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.IssueHistory.Any())
    {
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-history me-2"></i>Issue History</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Member</th>
                                <th>Issue Date</th>
                                <th>Due Date</th>
                                <th>Return Date</th>
                                <th>Fine</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in Model.IssueHistory)
                            {
                                <tr>
                                    <td>@issue.Member?.FirstName @issue.Member?.LastName</td>
                                    <td>@issue.DateIssue.ToShortDateString()</td>
                                    <td>@issue.DueDate.ToShortDateString()</td>
                                    <td>@(issue.ReturnDate?.ToShortDateString() ?? "N/A")</td>
                                    <td>
                                        @if (issue.FineAmount > 0)
                                        {
                                            <span class="text-danger fw-bold">$@issue.FineAmount.ToString("F2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-success">$0.00</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (book.Series != null && Model.SeriesBooks.Any())
    {
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-layer-group me-2"></i>More in @book.Series.Name</h5>
            </div>
            <div class="card-body position-relative px-5">
                <button class="btn btn-sm btn-outline-secondary series-arrow series-arrow-left" onclick="scrollSeries(-1)" id="seriesLeft">
                    <i class="fas fa-chevron-left"></i>
                </button>

                <div class="series-scroll" id="seriesScroll">
                    @foreach (var related in Model.SeriesBooks)
                    {
                        <a asp-action="Details" asp-route-id="@related.Id" class="text-decoration-none series-card-link">
                            <div class="card h-100 shadow-sm series-card">
                                @if (!string.IsNullOrEmpty(related.CoverImageUrl))
                                {
                                    <img src="@related.CoverImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                                }
                                else
                                {
                                    <img src="https://placehold.co/300x200?text=No+Cover" class="card-img-top" style="height:200px; object-fit:cover;" />
                                }
                                <div class="card-body p-2">
                                    <h6 class="card-title text-dark mb-1" style="font-size:0.9rem;">@related.Title</h6>
                                    <p class="text-muted mb-1" style="font-size:0.8rem;">@related.Author?.FirstName @related.Author?.LastName</p>
                                    @if (related.AvailableCopies > 0)
                                    {
                                        <span class="badge bg-success" style="font-size:0.7rem;">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger" style="font-size:0.7rem;">Out of Stock</span>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>

                <button class="btn btn-sm btn-outline-secondary series-arrow series-arrow-right" onclick="scrollSeries(1)" id="seriesRight">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    }

</div>

<style>
    .series-scroll {
        display: flex;
        gap: 1rem;
        overflow-x: hidden;
        scroll-behavior: smooth;
        padding: 0.5rem 0;
    }
    .series-card-link {
        flex: 0 0 260px;
    }
    .series-card {
        width: 260px;
        transition: transform 0.2s;
    }
    .series-card:hover {
        transform: translateY(-3px);
    }
    .series-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 2;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }
    .series-arrow-left {
        left: 8px;
    }
    .series-arrow-right {
        right: 8px;
    }
    .series-arrow:disabled {
        opacity: 0.3;
        pointer-events: none;
    }
</style>

@section Scripts {
    <script>
        function scrollSeries(direction) {
            var container = document.getElementById('seriesScroll');
            var scrollAmount = 280;
            container.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
        }

        document.addEventListener('DOMContentLoaded', function () {
            var container = document.getElementById('seriesScroll');
            var leftBtn = document.getElementById('seriesLeft');
            var rightBtn = document.getElementById('seriesRight');

            function updateArrows() {
                leftBtn.disabled = container.scrollLeft <= 0;
                rightBtn.disabled = container.scrollLeft + container.clientWidth >= container.scrollWidth - 5;
            }

            container.addEventListener('scroll', updateArrows);
            updateArrows();
        });
    </script>
}
