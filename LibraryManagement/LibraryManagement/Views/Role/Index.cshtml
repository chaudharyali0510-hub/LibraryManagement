@inject IAuthorizationService AuthorizationService
@model IEnumerable<LibraryManagement.Models.Identity.ApplicationRole>

<div class="container">
    <h2>Role Management</h2>

    @if ((await AuthorizationService.AuthorizeAsync(User, "Roles.Create")).Succeeded)
    {
        <a asp-action="Upsert" class="btn btn-primary">Add Role</a>
    }

    <table class="table table-bordered mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    <td>@role.Name</td>
                    <td>@role.Description</td>
                    <td>
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Roles.Edit")).Succeeded)
                        {
                            <a asp-action="Upsert" asp-route-id="@role.Id" class="btn btn-warning">Edit</a>
                        }
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Menus.Assign")).Succeeded)
                        {
                            <a asp-controller="Menu" asp-action="Assign" asp-route-roleId="@role.Id" class="btn btn-info">Menu Access</a>
                        }
                        @if ((await AuthorizationService.AuthorizeAsync(User, "Roles.Delete")).Succeeded)
                        {
                            <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
