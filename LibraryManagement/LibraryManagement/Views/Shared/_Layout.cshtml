@using System.Security.Claims
@using LibraryManagement.Services
@inject IMenuService MenuService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryManagement.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-book-open brand-icon"></i>
            <span class="brand-text">LibraryApp</span>
        </div>
        <nav class="sidebar-nav">
            @{
                var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                var menus = userId != null ? await MenuService.GetUserMenusAsync(userId) : new List<LibraryManagement.Models.Identity.MenuItem>();
            }
            @foreach (var menu in menus)
            {
                <a class="sidebar-link" asp-controller="@menu.Controller" asp-action="@menu.Action" data-controller="@menu.Controller">
                    <i class="@menu.IconClass"></i>
                    <span>@menu.Name</span>
                </a>
            }
            <div class="topbar-right">

                <partial name="_LoginPartial" />

            </div>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <h5 class="topbar-title mb-0">@ViewData["Title"]</h5>
            </div>
            <div class="topbar-right">
                <a class="topbar-link" asp-controller="Home" asp-action="Privacy">
                    <i class="fas fa-shield-alt"></i>
                </a>
            </div>
        </header>

        <main class="main-content">
            <div class="container-fluid px-4">
                @RenderBody()
            </div>
        </main>

        <footer class="dashboard-footer">
            <span>&copy; 2026 LibraryManagement</span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
