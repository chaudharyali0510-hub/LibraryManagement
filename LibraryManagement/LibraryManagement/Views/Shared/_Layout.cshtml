<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryManagement.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-book-open brand-icon"></i>
            <span class="brand-text">LibraryApp</span>
        </div>
        <nav class="sidebar-nav">
            <a class="sidebar-link" asp-controller="Home" asp-action="Index" data-controller="Home">
                <i class="fas fa-home"></i>
                <span>Dashboard</span>
            </a>
            <a class="sidebar-link" asp-controller="Book" asp-action="Index" data-controller="Book">
                <i class="fas fa-book"></i>
                <span>Books</span>
            </a>
            <a class="sidebar-link" asp-controller="Author" asp-action="Index" data-controller="Author">
                <i class="fas fa-pen-fancy"></i>
                <span>Authors</span>
            </a>
            <a class="sidebar-link" asp-controller="Publisher" asp-action="Index" data-controller="Publisher">
                <i class="fas fa-building"></i>
                <span>Publishers</span>
            </a>
            <a class="sidebar-link" asp-controller="Genre" asp-action="Index" data-controller="Genre">
                <i class="fas fa-tags"></i>
                <span>Genres</span>
            </a>
            <a class="sidebar-link" asp-controller="Member" asp-action="Index" data-controller="Member">
                <i class="fas fa-users"></i>
                <span>Members</span>
            </a>
            <a class="sidebar-link" asp-controller="BookIssue" asp-action="Index" data-controller="BookIssue">
                <i class="fas fa-exchange-alt"></i>
                <span>Issue / Return</span>
            </a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <h5 class="topbar-title mb-0">@ViewData["Title"]</h5>
            </div>
            <div class="topbar-right">
                <a class="topbar-link" asp-controller="Home" asp-action="Privacy">
                    <i class="fas fa-shield-alt"></i>
                </a>
            </div>
        </header>

        <main class="main-content">
            <div class="container-fluid px-4">
                @RenderBody()
            </div>
        </main>

        <footer class="dashboard-footer">
            <span>&copy; 2026 LibraryManagement</span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
